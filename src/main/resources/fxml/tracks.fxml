<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.u24589137.u24589137_chinook.controllers.TracksController">
   <children>
      <Button text="Add New Track" onAction="#openAddTrackDialog"/>
      <TableView fx:id="tracksTable" prefWidth="200.0">
        <columns>
            <TableColumn fx:id="trackCol" prefWidth="75.0" text="Track" />
            <TableColumn fx:id="albumCol" prefWidth="75.0" text="Album" />
            <TableColumn fx:id="artistCol" prefWidth="75.0" text="Artist" />
            <TableColumn fx:id="composerCol" prefWidth="75.0" text="Composer" />
            <TableColumn fx:id="genreCol" prefWidth="75.0" text="Genre" />
            <TableColumn fx:id="mediaTypeCol" prefWidth="75.0" text="Media Type" />
            <TableColumn fx:id="millisecondsCol" prefWidth="75.0" text="Milliseconds" />
            <TableColumn fx:id="bytesCol" prefWidth="75.0" text="Bytes" />
            <TableColumn fx:id="unitPriceCol" prefWidth="75.0" text="Unit Price" />
        </columns>
        <columnResizePolicy>
              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
      </TableView>
   </children>
</VBox>
