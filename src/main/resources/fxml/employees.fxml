<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/26"
      spacing="10"
      fx:controller="com.u24589137.u24589137_chinook.controllers.EmployeesController">

    <children>
        <TextField fx:id="searchField" promptText="Search by name or city..." />

        <TableView fx:id="table">
            <columns>
                <TableColumn fx:id="firstNameCol" text="First Name" />
                <TableColumn fx:id="lastNameCol" text="Last Name" />
                <TableColumn fx:id="titleCol" text="Title" />
                <TableColumn fx:id="cityCol" text="City" />
                <TableColumn fx:id="countryCol" text="Country" />
                <TableColumn fx:id="phoneCol" text="Phone" />
                <TableColumn fx:id="emailCol" text="Email" />
                <TableColumn fx:id="supervisorCol" text="Supervisor" />
                <TableColumn fx:id="isActiveCol" text="Is Active" />
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>